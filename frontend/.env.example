# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_BASE=http://localhost:3001

# Default mint URL
NEXT_PUBLIC_DEFAULT_MINT=https://mint.minibits.cash/Bitcoin

# Recovery scan parameters
NEXT_PUBLIC_DEFAULT_BATCH_SIZE=100
NEXT_PUBLIC_DEFAULT_GAP_LIMIT=300
NEXT_PUBLIC_NUM_BATCHES=25

# Ippon wallet API (used client-side for optional denomination swap)
NEXT_PUBLIC_IPPON_BASE=https://ippon.minibits.cash/v1
# Show swap option when recovered proof count exceeds this threshold
NEXT_PUBLIC_RECOMMENDED_SWAP_LIMIT=100

# Branding
NEXT_PUBLIC_PROJECT_NAME=Minibits
NEXT_PUBLIC_APP_NAME=RECOVERY
NEXT_PUBLIC_LOGO_URL=https://minibits.cash/icon-192.png
